**/.env.*
*.env.local
*.env.development
*.env.production
*.secret
*.key
*.pem
*.p12
*.pfx
*.crt

# Allow safe templates
!*.env.example
!example.env

# DATABASE
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

